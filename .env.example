# AI Provider (default: zen)
AI_PROVIDER=zen

# OpenCode Zen API (default provider)
ZEN_API_KEY=
ZEN_BASE_URL=https://api.opencode.ai/v1

# Alternative Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
FEATHERLESS_API_KEY=

# Model Override (optional — uses provider default otherwise)
MODEL_NAME=

# LangSmith Observability
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=internet-detective-ai

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Clerk Authentication
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Upstash Redis (caching)
REDIS_URL=
